---
/*
 * knowledge-graph.astro — Pagina dedicata al libro
 * "Knowledge Graph: dalla Teoria alla Pratica"
 *
 * TODO: Aggiornare AMAZON_BOOK_URL con l'URL reale Amazon.
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';

const AMAZON_BOOK_URL = '#'; // TODO: inserire URL Amazon reale

const parts = [
  { number: '1', title: 'Fondamenti', chapters: '1–4', desc: 'Teoria dei KG, modelli dati, query Cypher, ontologie e ragionamento' },
  { number: '2', title: 'Costruire con Python', chapters: '5–9', desc: 'Architettura, Vector Store, pipeline RAG, interfacce NL, KG Completion' },
  { number: '3', title: 'Avanzato', chapters: '10–16', desc: 'KG dinamici, produzione, pipeline da testo, metriche qualità, ontologie multi-schema' },
  { number: '4', title: 'MCP Protocol', chapters: '17–20', desc: 'Teoria MCP, architettura del protocollo, server MCP per Knowledge Graph' },
  { number: '5', title: 'Agent Framework', chapters: '21–23', desc: 'Agenti AI orchestrati, Microsoft Agent Framework, i 7 agenti del progetto' },
];

const stack = ['Python 3.11+', 'C# (.NET 9)', 'Neo4j', 'Redis for AI', 'Ollama', 'FastAPI', 'Docker', 'MCP', 'Microsoft Agent Framework'];

const highlights = [
  { icon: '📖', label: '23 capitoli + 4 appendici' },
  { icon: '🎨', label: '190 pagine full color' },
  { icon: '💻', label: 'Codice funzionante e testato' },
  { icon: '🏗️', label: 'Architetture reali enterprise' },
  { icon: '🤖', label: 'Multi-agent orchestration' },
  { icon: '🔗', label: 'MCP + Knowledge Graph' },
];
---

<BaseLayout
  title="Knowledge Graph: dalla Teoria alla Pratica — Agent Engineering Studio"
  description="Il libro completo su Knowledge Graph con Python, Neo4j, Redis, RAG, MCP e Agent Framework. Disponibile su Amazon."
>
  <main>
    <!-- Hero -->
    <section class="book-hero">
      <div class="container">
        <a href="/" class="back-link">&larr; Agent Engineering Studio</a>

        <div class="book-hero__layout">
          <div class="book-hero__info">
            <span class="badge-new">Aprile 2026</span>
            <h1 class="book-hero__title">
              Knowledge Graph:<br/>
              <span class="accent">dalla Teoria alla Pratica</span>
            </h1>
            <p class="book-hero__subtitle">
              Un percorso completo dalla teoria accademica all'implementazione enterprise
              con Python, MCP e Agent Framework.
            </p>
            <p class="book-hero__author">
              di <strong>Giuseppe Zileni</strong> — AI Senior Software Architect @ Hevolus Innovation
            </p>

            <!-- Amazon CTA -->
            <div class="book-hero__actions">
              <a href={AMAZON_BOOK_URL} target="_blank" rel="noopener noreferrer" class="btn-amazon">
                Acquista su Amazon
              </a>
              <a
                href={AMAZON_BOOK_URL}
                target="_blank"
                rel="noopener noreferrer"
                class="amazon-badge-wrap"
                aria-label="Available at Amazon"
              >
                <img
                  src="/agent-engineering-studio-site/badges/available_at_amazon_en_horizontal_drk.png"
                  alt="Available at Amazon"
                  class="amazon-badge-img"
                  width="180"
                  height="46"
                  loading="eager"
                />
              </a>
            </div>
            <p class="trademark">
              Amazon's trademark is used under license from Amazon.com, Inc. or its affiliates.
            </p>
          </div>

          <!-- Book cover mock -->
          <div class="book-hero__cover">
            <div class="cover-mock">
              <div class="cover-mock__inner">
                <span class="cover-mock__tag">BOOK</span>
                <span class="cover-mock__title">Knowledge<br/>Graph</span>
                <span class="cover-mock__sub">dalla Teoria<br/>alla Pratica</span>
                <span class="cover-mock__author">Giuseppe Zileni</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Highlights -->
    <section class="highlights">
      <div class="container">
        <div class="highlights__grid">
          {highlights.map((h) => (
            <div class="highlight-item">
              <span class="highlight-item__icon" aria-hidden="true">{h.icon}</span>
              <span class="highlight-item__label">{h.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Description -->
    <section class="description">
      <div class="container">
        <h2 class="section-title">Di cosa parla il libro</h2>
        <div class="description__content">
          <p>
            Questo libro porta il lettore dal concetto di <strong>grafo di conoscenza</strong> fino a un
            sistema funzionante in produzione, capace di rispondere a domande in linguaggio naturale su
            documenti aziendali.
          </p>
          <p>
            Copre l'intero ciclo: modelli dati, ontologie, pipeline RAG, Vector Store, LLM,
            <strong>Model Context Protocol</strong> e orchestrazione <strong>multi-agente</strong>
            con Microsoft Agent Framework.
          </p>
          <p>
            Pensato per <strong>sviluppatori Python e C#</strong>, data engineer e AI engineer che vogliono
            costruire un KG reale, ma anche per <strong>CTO e product manager</strong> che vogliono
            valutare il potenziale dei Knowledge Graph e stimare il ROI.
          </p>
        </div>
      </div>
    </section>

    <!-- Table of contents -->
    <section class="toc">
      <div class="container">
        <h2 class="section-title">Struttura del libro</h2>
        <div class="toc__grid">
          {parts.map((part) => (
            <div class="toc-card">
              <div class="toc-card__header">
                <span class="toc-card__number">Parte {part.number}</span>
                <span class="toc-card__chapters">Cap. {part.chapters}</span>
              </div>
              <h3 class="toc-card__title">{part.title}</h3>
              <p class="toc-card__desc">{part.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Stack -->
    <section class="tech-stack">
      <div class="container">
        <h2 class="section-title">Stack Tecnologico</h2>
        <div class="stack-tags">
          {stack.map((tech) => (
            <span class="stack-tag">{tech}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- Formats -->
    <section class="formats">
      <div class="container">
        <h2 class="section-title">Formati disponibili</h2>
        <div class="formats__grid">
          <div class="format-card">
            <span class="format-card__icon" aria-hidden="true">📖</span>
            <h3 class="format-card__title">Paperback</h3>
            <p class="format-card__detail">7" × 10" — Full color — 190 pagine</p>
            <p class="format-card__detail">Carta bianca premium, copertina lucida</p>
          </div>
          <div class="format-card">
            <span class="format-card__icon" aria-hidden="true">📱</span>
            <h3 class="format-card__title">eBook Kindle</h3>
            <p class="format-card__detail">EPUB 3.0 — Reflowable</p>
            <p class="format-card__detail">29 capitoli, 39 immagini, TOC navigabile</p>
          </div>
        </div>

        <!-- Final Amazon CTA -->
        <div class="formats__cta">
          <a href={AMAZON_BOOK_URL} target="_blank" rel="noopener noreferrer" class="btn-amazon btn-amazon--lg">
            Acquista su Amazon
          </a>
          <a
            href={AMAZON_BOOK_URL}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Available at Amazon"
          >
            <img
              src="/agent-engineering-studio-site/badges/available_at_amazon_en_horizontal_drk.png"
              alt="Available at Amazon"
              class="amazon-badge-img"
              width="180"
              height="46"
              loading="lazy"
            />
          </a>
          <p class="trademark">
            Amazon's trademark is used under license from Amazon.com, Inc. or its affiliates.
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Variables inherit from global.css ── */

  /* ── Back link ── */
  .back-link {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
    transition: color var(--transition-fast);
  }
  .back-link:hover { color: var(--color-accent); }

  /* ── Hero ── */
  .book-hero {
    padding: var(--space-3xl) 0 var(--space-2xl);
  }

  .book-hero__layout {
    display: flex;
    gap: var(--space-3xl);
    align-items: flex-start;
  }

  .book-hero__info {
    flex: 1;
  }

  .badge-new {
    display: inline-block;
    padding: 0.2em 0.8em;
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-bg);
    background: var(--color-accent);
    border-radius: 999px;
    margin-bottom: var(--space-lg);
  }

  .book-hero__title {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .accent { color: var(--color-accent); }

  .book-hero__subtitle {
    font-size: clamp(0.95rem, 2vw, 1.15rem);
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 560px;
    margin-bottom: var(--space-md);
  }

  .book-hero__author {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }

  .book-hero__author strong {
    color: var(--color-text);
  }

  /* ── Amazon CTA ── */
  .book-hero__actions {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
    margin-bottom: var(--space-sm);
  }

  .btn-amazon {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0.7em 1.6em;
    background: #ff9900;
    color: #0a0e17;
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 700;
    border-radius: var(--border-radius);
    text-decoration: none;
    transition: background var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .btn-amazon:hover {
    background: #ffad33;
    color: #0a0e17;
    transform: translateY(-2px);
    box-shadow: 0 4px 24px rgba(255, 153, 0, 0.35);
  }

  .btn-amazon--lg {
    font-size: 1rem;
    padding: 0.8em 2em;
  }

  .amazon-badge-wrap {
    display: inline-block;
    line-height: 0;
  }

  .amazon-badge-img {
    height: 40px;
    width: auto;
    display: block;
  }

  .trademark {
    font-size: 0.6rem;
    color: var(--color-text-muted);
    opacity: 0.4;
  }

  /* ── Cover mock ── */
  .book-hero__cover {
    flex-shrink: 0;
  }

  .cover-mock {
    width: 220px;
    height: 314px;
    perspective: 800px;
  }

  .cover-mock__inner {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #0B3D91 0%, #1A5276 60%, #2471A3 100%);
    border-radius: 4px 12px 12px 4px;
    box-shadow:
      -4px 0 0 #08244d,
      -6px 1px 0 #061a38,
      0 8px 40px rgba(0,0,0,0.5);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: var(--space-lg);
    gap: var(--space-sm);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cover-mock__inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(0,229,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,255,0.04) 1px, transparent 1px);
    background-size: 20px 20px;
    pointer-events: none;
  }

  .cover-mock__tag {
    font-family: var(--font-heading);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: #ff9900;
    text-transform: uppercase;
  }

  .cover-mock__title {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.15;
  }

  .cover-mock__sub {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.3;
  }

  .cover-mock__author {
    font-family: var(--font-heading);
    font-size: 0.65rem;
    color: rgba(255,255,255,0.5);
    margin-top: var(--space-sm);
  }

  /* ── Highlights ── */
  .highlights {
    padding: var(--space-xl) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .highlights__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md);
  }

  .highlight-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .highlight-item__icon { font-size: 1.1rem; }

  /* ── Section titles ── */
  .section-title {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  /* ── Description ── */
  .description {
    padding: var(--space-3xl) 0;
  }

  .description__content {
    max-width: 680px;
    margin: 0 auto;
  }

  .description__content p {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    text-align: center;
    margin-bottom: var(--space-md);
  }

  .description__content strong {
    color: var(--color-text);
  }

  /* ── TOC ── */
  .toc {
    padding: var(--space-2xl) 0 var(--space-3xl);
    border-top: 1px solid var(--color-border);
  }

  .toc__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    max-width: 720px;
    margin: 0 auto;
  }

  .toc-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    padding: var(--space-lg);
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .toc-card:hover {
    border-color: rgba(0,229,255,0.3);
    box-shadow: 0 0 16px var(--color-accent-glow);
  }

  .toc-card__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-xs);
  }

  .toc-card__number {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .toc-card__chapters {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .toc-card__title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }

  .toc-card__desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* ── Stack ── */
  .tech-stack {
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--color-border);
  }

  .stack-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm);
  }

  .stack-tag {
    padding: 0.3em 0.9em;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    transition: border-color var(--transition-base);
  }

  .stack-tag:hover {
    border-color: rgba(0,229,255,0.3);
    color: var(--color-accent);
  }

  /* ── Formats ── */
  .formats {
    padding: var(--space-2xl) 0 var(--space-3xl);
    border-top: 1px solid var(--color-border);
  }

  .formats__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    max-width: 560px;
    margin: 0 auto var(--space-2xl);
  }

  .format-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    padding: var(--space-lg);
    text-align: center;
  }

  .format-card__icon { font-size: 2rem; display: block; margin-bottom: var(--space-sm); }
  .format-card__title { font-family: var(--font-heading); font-size: 1rem; font-weight: 700; color: var(--color-text); margin-bottom: var(--space-xs); }
  .format-card__detail { font-size: 0.8rem; color: var(--color-text-muted); line-height: 1.5; }

  .formats__cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  /* ── Responsive ── */
  @media (max-width: 700px) {
    .book-hero__layout {
      flex-direction: column-reverse;
      align-items: center;
      text-align: center;
    }
    .book-hero__subtitle { margin-left: auto; margin-right: auto; }
    .book-hero__actions { justify-content: center; }
    .formats__grid { grid-template-columns: 1fr; }
    .cover-mock { width: 180px; height: 257px; }
    .cover-mock__title { font-size: 1.1rem; }
  }
</style>
